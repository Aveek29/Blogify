# DevBlog Hub — Backend Environment Variables
# Copy this file to .env and fill in your values

PORT=5000

# MongoDB Atlas connection string
# Get yours from Atlas → Database → Connect → Drivers
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/devblog?retryWrites=true&w=majority

# JWT secret — generate a random string
JWT_SECRET=your_random_jwt_secret_here

# Groq API key — get yours at https://console.groq.com
GROQ_API_KEY=gsk_your_groq_api_key_here
